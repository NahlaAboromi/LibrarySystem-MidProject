<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ConnectionsController" stylesheets="@Connections.css">
   <children>
      <TableView fx:id="connectionsTable" layoutX="10.0" layoutY="10.0" prefHeight="380.0" prefWidth="580.0">
        <columns>
          <TableColumn fx:id="ipColumn" text="IP Address" prefWidth="200.0"/>
          <TableColumn fx:id="hostColumn" text="Host Name" prefWidth="200.0"/>
          <TableColumn fx:id="statusColumn" text="Status" prefWidth="150.0"/>
        </columns>
      </TableView>
      <Label fx:id="errorLabel" layoutX="10.0" layoutY="400.0" styleClass="error-label"/>
      <Button fx:id="btnExit" layoutX="500.0" layoutY="350.0" text="Exit" onAction="#handleExit" styleClass="button"/>
   </children>
</AnchorPane>
