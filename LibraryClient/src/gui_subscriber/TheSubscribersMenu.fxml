<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.paint.CycleMethod?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<AnchorPane prefHeight="600.0" prefWidth="500.0" style="-fx-background-image: url('/BlibBackGround.jpg'); -fx-background-size: cover; -fx-background-position: center center;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.SubscriberMenuController">
    <!-- Logo in Top-Right Corner (Locked Position) -->
    <ImageView fitHeight="50.0" fitWidth="50.0" preserveRatio="true" AnchorPane.topAnchor="10" AnchorPane.rightAnchor="10">
        <image>
            <Image url="@/Logo.png"/>
        </image>
    </ImageView>

    <!-- Fancy Header Label (Centered) -->
    <Label text="SUBSCRIBER MENU" style="-fx-font-weight: bold;" AnchorPane.topAnchor="30" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" alignment="CENTER">
        <font>
            <Font name="Arial" size="28" />
        </font>
        <textFill>
            <LinearGradient startX="0" startY="0" endX="1" endY="1">
                <stops>
                    <Stop offset="0.0" color="#ab5843" />
                    <Stop offset="1.0" color="#e8d3cf" />
                </stops>
            </LinearGradient>
        </textFill>
        <effect>
            <DropShadow radius="5.0" offsetX="2.0" offsetY="2.0" color="#ab5843" />
        </effect>
    </Label>

    <!-- Buttons Container -->
    <VBox alignment="CENTER" spacing="20" AnchorPane.topAnchor="120" AnchorPane.leftAnchor="50" AnchorPane.rightAnchor="50">
        <!-- Buttons for Subscriber Actions -->
        <Button onAction="#handleSearchButton" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-weight: bold; -fx-font-size: 14px; -fx-pref-width: 300px; -fx-pref-height: 40px;" text="Search for a Book" />
        <Button onAction="#handleOrderButton" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-weight: bold; -fx-font-size: 14px; -fx-pref-width: 300px; -fx-pref-height: 40px;" text="Order Book" />
        <Button onAction="#handleExtendBorrowingButton" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-weight: bold; -fx-font-size: 14px; -fx-pref-width: 300px; -fx-pref-height: 40px;" text="Extend Borrowing" />
        <Button onAction="#handleActivityHistoryButton" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-weight: bold; -fx-font-size: 14px; -fx-pref-width: 300px; -fx-pref-height: 40px;" text="Activity History" />
        <Button onAction="#handleUpdatePersonalDetailsButton" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-weight: bold; -fx-font-size: 14px; -fx-pref-width: 300px; -fx-pref-height: 40px;" text="Update Personal Details" />

        <!-- Go To Home Button (At the End) -->
        <Button onAction="#handleHomeButton" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-weight: bold; -fx-font-size: 14px; -fx-pref-width: 300px; -fx-pref-height: 40px;" text="Back to Home" />
    </VBox>
</AnchorPane>