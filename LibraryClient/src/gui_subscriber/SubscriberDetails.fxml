<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-image: url('/BlibBackGround.jpg'); -fx-background-size: cover;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.SubscriberFormController">
   <children>
      <!-- Logo in Top-Right Corner -->
      <ImageView fitHeight="50.0" fitWidth="50.0" preserveRatio="true" AnchorPane.topAnchor="10" AnchorPane.rightAnchor="10">
         <image>
            <Image url="@/Logo.png" />
         </image>
      </ImageView>

      <!-- Fancy Header -->
      <Label layoutX="250.0" layoutY="20.0" prefHeight="59.0" prefWidth="300.0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-padding: 10;" text="SUBSCRIBER DETAILS">
         <textFill>
            <LinearGradient startX="0" startY="0" endX="1" endY="1">
               <stops>
                  <Stop offset="0.0" color="#ab5843" />
                  <Stop offset="1.0" color="#e8d3cf" />
               </stops>
            </LinearGradient>
         </textFill>
         <effect>
            <DropShadow radius="3.0" offsetX="2.0" offsetY="2.0" color="#ab5843" />
         </effect>
      </Label>

      <!-- ID Field -->
      <Label fx:id="lblId" layoutX="150.0" layoutY="105.0" style="-fx-text-fill: #ab5843; -fx-font-size: 14px; -fx-font-weight: bold;" text="ID:" />
      <TextField fx:id="txtId" layoutX="300.0" layoutY="100.0" prefHeight="32.0" prefWidth="350.0" focusTraversable="false"  promptText="Enter Subscriber ID" style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-padding: 5; -fx-font-style: italic; -fx-border-radius: 5; -fx-background-radius: 5;" />

      <!-- Name Field -->
      <Label fx:id="lblName" layoutX="150.0" layoutY="155.0" style="-fx-text-fill: #ab5843; -fx-font-size: 14px; -fx-font-weight: bold;" text="Name:" />
      <TextField fx:id="txtName" layoutX="300.0" layoutY="150.0" prefHeight="32.0" prefWidth="350.0" focusTraversable="false"  promptText="Enter Name" style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-padding: 5; -fx-font-style: italic; -fx-border-radius: 5; -fx-background-radius: 5;" />

      <!-- Username Field -->
      <Label fx:id="lblUsername" layoutX="150.0" layoutY="205.0" style="-fx-text-fill: #ab5843; -fx-font-size: 14px; -fx-font-weight: bold;" text="Username:" />
      <TextField fx:id="txtUsername" layoutX="300.0" layoutY="200.0" prefHeight="32.0" prefWidth="350.0" focusTraversable="false"  promptText="Enter Username" style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-padding: 5; -fx-font-style: italic; -fx-border-radius: 5; -fx-background-radius: 5;" />

      <!-- Phone Field -->
      <Label fx:id="lblPhone" layoutX="150.0" layoutY="255.0" style="-fx-text-fill: #ab5843; -fx-font-size: 14px; -fx-font-weight: bold;" text="Phone:" />
      <TextField fx:id="txtPhone" layoutX="300.0" layoutY="250.0" prefHeight="32.0" prefWidth="350.0" focusTraversable="false"  promptText="Enter Phone" style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-padding: 5; -fx-font-style: italic; -fx-border-radius: 5; -fx-background-radius: 5;" />

      <!-- Email Field -->
      <Label fx:id="lblEmail" layoutX="150.0" layoutY="305.0" style="-fx-text-fill: #ab5843; -fx-font-size: 14px; -fx-font-weight: bold;" text="Email:" />
      <TextField fx:id="txtEmail" layoutX="300.0" layoutY="300.0" prefHeight="32.0" prefWidth="350.0" focusTraversable="false"  promptText="Enter Email" style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-padding: 5; -fx-font-style: italic; -fx-border-radius: 5; -fx-background-radius: 5;" />

      <!-- Status Field -->
      <Label fx:id="lblStatus" layoutX="150.0" layoutY="355.0" style="-fx-text-fill: #ab5843; -fx-font-size: 14px; -fx-font-weight: bold;" text="Status:" />
      <Label fx:id="lblStatusValue" layoutX="300.0" layoutY="355.0" style="-fx-text-fill: #ab5843; -fx-font-size: 14px;" />

      <!-- Password Field -->
      <Label fx:id="lblPassword" layoutX="150.0" layoutY="405.0" style="-fx-text-fill: #ab5843; -fx-font-size: 14px; -fx-font-weight: bold;" text="Password:" />
      <TextField fx:id="txtPassword" focusTraversable="false"  layoutX="300.0" layoutY="400.0" prefHeight="32.0" prefWidth="350.0" promptText="Enter Password" style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-padding: 5; -fx-font-style: italic; -fx-border-radius: 5; -fx-background-radius: 5;" />

      <!-- Error Label -->
      <Label fx:id="errorLabel" layoutX="150.0" layoutY="450.0" style="-fx-text-fill: #ab5843; -fx-font-size: 12px;" />

      <!-- Buttons -->
      <Button fx:id="btnSave" layoutX="250.0" layoutY="500.0" mnemonicParsing="false" onAction="#handleSave" style="-fx-background-color: #ab5843; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-pref-width: 100px; -fx-pref-height: 40px;" text="Save" />
      
      <Button fx:id="btnGoHome" layoutX="450.0" layoutY="500.0" mnemonicParsing="false" onAction="#handleGoHome" style="-fx-background-color: #ab5843; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-pref-width: 100px; -fx-pref-height: 40px;" text="Home" />
   </children>
</AnchorPane>