<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-image: url('/BlibBackGround.jpg'); -fx-background-size: 100% 100%; -fx-background-position: center center;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ExtendReturnDateController">
    <children>
        <!-- Logo in Top-Right Corner -->
        <ImageView fitHeight="50.0" fitWidth="50.0" preserveRatio="true" AnchorPane.rightAnchor="10" AnchorPane.topAnchor="10">
            <image>
                <Image url="@/Logo.png" />
            </image>
        </ImageView>

        <!-- Header -->
        <Text layoutX="50.0" layoutY="50.0" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="EXTEND RETURN DATE">
            <fill>
                <LinearGradient endX="1" endY="1" startX="0" startY="0">
                    <stops>
                        <Stop color="#ab5843" offset="0.0" />
                        <Stop color="#e8d3cf" offset="1.0" />
                    </stops>
                </LinearGradient>
            </fill>
            <effect>
                <DropShadow color="#ab5843" offsetX="2.0" offsetY="2.0" radius="3.0" />
            </effect>
        </Text>

        <!-- Book ID Label -->
        <Label fx:id="bookIdLabel" layoutX="50.0" layoutY="100.0" style="-fx-font-size: 16px; -fx-text-fill: #ab5843; -fx-font-weight: bold;" text="Book ID:" />

        <!-- Subscriber ID Label -->
        <Label fx:id="subscriberIdLabel" layoutX="50.0" layoutY="140.0" style="-fx-font-size: 16px; -fx-text-fill: #ab5843; -fx-font-weight: bold;" text="Subscriber ID:" />

        <!-- New Return Date Label and DatePicker -->
        <Label layoutX="50.0" layoutY="180.0" style="-fx-font-size: 16px; -fx-text-fill: #ab5843; -fx-font-weight: bold;" text="New Return Date:" />
        <DatePicker fx:id="newReturnDatePicker" layoutX="200.0" layoutY="175.0" style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" />

        <!-- Error Label -->
        <Label fx:id="errorLabel" layoutX="50.0" layoutY="220.0" prefHeight="30.0" prefWidth="540.0" style="-fx-text-fill: red; -fx-font-size: 14px; -fx-font-weight: bold;" text="" />

        <!-- Confirm Button -->
        <Button fx:id="confirmButton" layoutX="50.0" layoutY="270.0" onAction="#handleConfirm" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-border-radius: 5; -fx-background-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);" text="Confirm" />
    </children>
</AnchorPane>
