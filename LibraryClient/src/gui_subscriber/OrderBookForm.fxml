<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="343.0" prefWidth="406.0" style="-fx-background-image: url('/BlibBackGround.jpg'); -fx-background-size: cover; -fx-background-position: center center;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">
    <!-- Logo in Top-Right Corner (Locked Position) -->
    <ImageView fitHeight="50.0" fitWidth="56.0" preserveRatio="true" AnchorPane.rightAnchor="10" AnchorPane.topAnchor="10">
        <image>
            <Image url="@/Logo.png" />
        </image>
    </ImageView>

    <!-- Fancy Header -->
    <Text layoutX="49.0" layoutY="44.0" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="BOOK ORDER FORM">
        <fill>
            <LinearGradient endX="1" endY="1" startX="0" startY="0">
                <stops>
                    <Stop color="#ab5843" offset="0.0" />
                    <Stop color="#e8d3cf" offset="1.0" />
                </stops>
            </LinearGradient>
        </fill>
        <effect>
            <DropShadow color="#ab5843" offsetX="2.0" offsetY="2.0" radius="3.0" />
        </effect>
    </Text>

    <!-- Subscriber ID Field -->
    <TextField fx:id="subscriberIDField" focusTraversable="false" layoutX="100.0" layoutY="81.0" maxHeight="29.0" prefWidth="187.0" promptText="Subscriber ID" style="-fx-alignment: center;-fx-background-color: transparent; -fx-font-family: 'Courier New'; -fx-font-size: 16px; -fx-prompt-text-fill: #8a4636; -fx-text-fill: #ab5843;" />

    <!-- GridPane for Parallel Input Fields -->
    <GridPane hgap="20" layoutX="15.0" layoutY="130.0" prefHeight="83.0" prefWidth="382.0" vgap="10">
        <!-- Book Name Label and Field -->
        <Label prefHeight="20.0" prefWidth="146.0" style="-fx-text-fill: #ab5843; -fx-font-size: 14px;" text="Enter Book Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="BookNameField" prefWidth="200" promptText="Book Name" style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-prompt-text-fill: #8a4636;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        <TextField fx:id="bookAuthorField" prefWidth="200" promptText="Book Author" style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-prompt-text-fill: #8a4636;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
   
        <!-- Book Author Label and Field -->
        <Label prefHeight="20.0" prefWidth="146.0" style="-fx-text-fill: #ab5843; -fx-font-size: 14px;" text="Enter Author Name:" GridPane.rowIndex="1" />

        <!-- Column and Row Constraints -->
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT" maxWidth="143.0" minWidth="108.0" prefWidth="143.0" />
            <ColumnConstraints halignment="LEFT" maxWidth="228.0" minWidth="193.0" prefWidth="193.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints maxHeight="45.0" minHeight="34.0" prefHeight="34.0" />
            <RowConstraints maxHeight="26.0" minHeight="15.0" prefHeight="26.0" />
        </rowConstraints>
    </GridPane>

    <!-- Error Label -->
    <Label fx:id="errorLabel" layoutX="82.0" layoutY="224.0" prefHeight="31.0" prefWidth="222.0" style="-fx-text-fill: #ab5843; -fx-font-size: 12px;" textAlignment="CENTER" />

    <!-- Buttons -->
    <Button fx:id="OrderBook" layoutX="164.0" layoutY="255.0" mnemonicParsing="false" onAction="#handleOrderBook" prefHeight="43.0" prefWidth="122.0" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-weight: bold; -fx-font-size: 14px;" text="Order Book">
        <effect>
            <DropShadow color="#ab5843" offsetX="2.0" offsetY="2.0" radius="3.0" />
        </effect>
    </Button>

    <Button fx:id="BackHome" layoutX="14.0" layoutY="298.0" mnemonicParsing="false" onAction="#handleGoToHome" prefHeight="31.0" prefWidth="135.0" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-weight: bold; -fx-font-size: 14px;" text="Back To Home">
        <effect>
            <DropShadow color="#ab5843" offsetX="2.0" offsetY="2.0" radius="3.0" />
        </effect>
    </Button>
</AnchorPane>
