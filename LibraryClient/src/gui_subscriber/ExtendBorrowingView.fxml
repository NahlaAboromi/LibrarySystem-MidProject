<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="550.0" prefWidth="540.0" style="-fx-background-image: url('/BlibBackGround.jpg'); -fx-background-size: cover; -fx-background-position: center center;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ExtendBorrowingController">
    <!-- Logo in Top-Right Corner (Locked Position) -->
    <ImageView fitHeight="50.0" fitWidth="50.0" preserveRatio="true" AnchorPane.rightAnchor="10" AnchorPane.topAnchor="10">
        <image>
            <Image url="@/Logo.png" />
        </image>
    </ImageView>

    <!-- Fancy Header -->
    <Text layoutX="137.0" layoutY="44.0" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="EXTEND BORROWING">
        <fill>
            <LinearGradient endX="1" endY="1" startX="0" startY="0">
                <stops>
                    <Stop color="#ab5843" offset="0.0" />
                    <Stop color="#e8d3cf" offset="1.0" />
                </stops>
            </LinearGradient>
        </fill>
        <effect>
            <DropShadow color="#ab5843" offsetX="2.0" offsetY="2.0" radius="3.0" />
        </effect>
    </Text>

    <!-- Subscriber ID Field -->
    <TextField fx:id="subscriberIdField" focusTraversable="false" layoutX="176.5" layoutY="90.0" maxHeight="29.0" prefWidth="187.0" promptText="Subscriber ID" style="-fx-background-color: transparent; -fx-font-family: 'Courier New'; -fx-font-size: 16px; -fx-prompt-text-fill: #8a4636; -fx-text-fill: #ab5843;-fx-alignment: center;" />
    <!-- GridPane for Parallel Input Fields -->
    <GridPane hgap="20" layoutX="90.0" layoutY="150.0" vgap="10">
        <!-- Current Date Label and DatePicker -->
        <Label prefHeight="20.0" prefWidth="123.0" style="-fx-text-fill: #ab5843; -fx-font-size: 14px;" text="Current Date:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
     

        <!-- Book Name Label and Field -->
        <Label prefHeight="20.0" prefWidth="123.0" style="-fx-text-fill: #ab5843; -fx-font-size: 14px;" text="Enter Book Name:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="bookNameField" prefWidth="200" promptText="Book Name" style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-prompt-text-fill: #8a4636;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <!-- Book Author Label and Field -->
        <Label style="-fx-text-fill: #ab5843; -fx-font-size: 14px;" text="Enter Author Name:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="bookAuthorField" prefWidth="200" promptText="Book Author" style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-prompt-text-fill: #8a4636;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        <TextField fx:id="currentDateField" editable="false" promptText="Current Date" style="-fx-background-color: #e8d3cf; -fx-font-size: 14px;" GridPane.columnIndex="1" />

        <!-- Column and Row Constraints -->
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT" />
            <ColumnConstraints halignment="LEFT" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
        </rowConstraints>
    </GridPane>

    <!-- Error Label -->
    <Label fx:id="errorLabel" layoutX="36.0" layoutY="300.0" prefHeight="31.0" prefWidth="466.0" style="-fx-text-fill: #ab5843; -fx-font-size: 12px;" textAlignment="CENTER" />

    <!-- Buttons -->
    <Button fx:id="extendLoanButton" layoutX="219.0" layoutY="357.0" mnemonicParsing="false" onAction="#handleExtendLoan" prefHeight="43.0" prefWidth="112.0" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-weight: bold; -fx-font-size: 14px;" text="Extend Loan">
        <effect>
            <DropShadow color="#ab5843" offsetX="2.0" offsetY="2.0" radius="3.0" />
        </effect>
    </Button>

    <Button fx:id="backHomeButton" layoutX="14.0" layoutY="412.0" mnemonicParsing="false" onAction="#handleGoToHome" prefHeight="31.0" prefWidth="135.0" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-weight: bold; -fx-font-size: 14px;" text="Back To Home">
        <effect>
            <DropShadow color="#ab5843" offsetX="2.0" offsetY="2.0" radius="3.0" />
        </effect>
    </Button>
</AnchorPane>
