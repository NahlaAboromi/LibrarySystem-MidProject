<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<AnchorPane prefHeight="700.0" prefWidth="900.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/22" style="-fx-background-color: #fbf2ec;">
    <children>
        <TableView fx:id="loanExtensionsTable" layoutX=".0" layoutY="10.0" prefHeight="550.0" prefWidth="1400.0" style="-fx-background-color: #e8d3cf; -fx-border-color: #ab5843; -fx-border-width: 2px;">
            <columns>
                <TableColumn fx:id="extensionIdColumn" text="Extension ID" prefWidth="100.0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ab5843;" />
                <TableColumn fx:id="subscriberIdColumn" text="Subscriber ID" prefWidth="100.0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ab5843;" />
                <TableColumn fx:id="bookIdColumn" text="Book ID" prefWidth="100.0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ab5843;" />
                <TableColumn fx:id="bookNameColumn" text="Book Name" prefWidth="150.0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ab5843;" />
                <TableColumn fx:id="authorColumn" text="Author" prefWidth="150.0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ab5843;" />
                <TableColumn fx:id="originalReturnDateColumn" text="Original Return Date" prefWidth="150.0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ab5843;" />
                <TableColumn fx:id="newReturnDateColumn" text="New Return Date" prefWidth="150.0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ab5843;" />
                <TableColumn fx:id="extensionDateColumn" text="Extension Date" prefWidth="150.0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ab5843;" />
                <TableColumn fx:id="extensionStatusColumn" text="Status" prefWidth="100.0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ab5843;" />
                <TableColumn fx:id="RejectionReason" text="Rejection Reason" prefWidth="550" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ab5843;" />
                <TableColumn fx:id="librarianNameColumn" text="Librarian Name" prefWidth="150.0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ab5843;" />
        
            </columns>
        </TableView>
        <Label fx:id="errorLabel" layoutX="10.0" layoutY="570.0" text="" style="-fx-font-size: 14px; -fx-text-fill: red;" />
              <!-- Return Button -->
      <Button fx:id="returnButton" onAction="#handleGoToHome" text="Back" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #ab5843; -fx-text-fill: white; -fx-padding: 10px 20px;" 
              AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0" />
    </children>
</AnchorPane>
