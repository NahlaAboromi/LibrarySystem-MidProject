<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.paint.CycleMethod?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="540.0" style="-fx-background-image: url('/BlibBackGround.jpg'); -fx-background-size: 100% 100%; -fx-background-position: center center;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ReturnBookController">
    <children>
        <!-- Logo in Top-Right Corner -->
        <ImageView fitHeight="50.0" fitWidth="50.0" preserveRatio="true" AnchorPane.topAnchor="10" AnchorPane.rightAnchor="10">
            <image>
                <Image url="@/Logo.png" />
            </image>
        </ImageView>

        <!-- Header -->
        <Text layoutX="50.0" layoutY="50.0" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="RETURN BOOK">
            <fill>
                <LinearGradient startX="0" startY="0" endX="1" endY="1">
                    <stops>
                        <Stop offset="0.0" color="#ab5843" />
                        <Stop offset="1.0" color="#e8d3cf" />
                    </stops>
                </LinearGradient>
            </fill>
            <effect>
                <DropShadow radius="3.0" offsetX="2.0" offsetY="2.0" color="#ab5843" />
            </effect>
        </Text>

        <!-- Subscriber ID -->
        <HBox layoutX="50.0" layoutY="100.0" spacing="10">
            <Label text="Subscriber ID:" style="-fx-font-size: 14px; -fx-text-fill: #ab5843; -fx-font-weight: bold;" prefWidth="120"/>
            <TextField fx:id="SubscriberIdField" promptText="Enter Subscriber ID" prefWidth="300"
                       style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-padding: 5; -fx-font-style: italic; -fx-border-radius: 5; -fx-background-radius: 5;"/>
        </HBox>

        <!-- Book ID -->
        <HBox layoutX="50.0" layoutY="150.0" spacing="10">
            <Label text="Book ID:" style="-fx-font-size: 14px; -fx-text-fill: #ab5843; -fx-font-weight: bold;" prefWidth="120"/>
            <TextField fx:id="BookIdField" promptText="Enter Book ID" prefWidth="300"
                       style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-padding: 5; -fx-font-style: italic; -fx-border-radius: 5; -fx-background-radius: 5;"/>
        </HBox>

        <!-- Error Label -->
        <Label fx:id="errorLabel" layoutX="50.0" layoutY="200.0" prefHeight="30.0" prefWidth="340.0" textAlignment="CENTER" textFill="#ab5843" 
               style="-fx-font-size: 12px; -fx-font-weight: bold;"/>

        <!-- Buttons -->
        <HBox layoutX="50.0" layoutY="250.0" spacing="20">
            <Button onAction="#handleReturnBook" text="Return" 
                    style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10; -fx-border-radius: 5; -fx-background-radius: 5;"/>
            <Button onAction="#handleGoToHome" text="Back To Home" 
                    style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10; -fx-border-radius: 5; -fx-background-radius: 5;"/>
        </HBox>
    </children>
</AnchorPane>