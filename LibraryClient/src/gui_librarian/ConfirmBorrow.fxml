<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.paint.CycleMethod?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0"
	style="-fx-background-image: url('/BlibBackGround.jpg'); -fx-background-size: 100% 100%; -fx-background-position: center center;"
	xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="controllers.ConfirmBorrowController">
	<children>
		<!-- Logo in Top-Right Corner -->
		<ImageView fitHeight="50.0" fitWidth="50.0"
			preserveRatio="true" AnchorPane.topAnchor="10"
			AnchorPane.rightAnchor="10">
			<image>
				<Image url="@/Logo.png" />
			</image>
		</ImageView>

		<!-- Centered Content -->
		<VBox alignment="TOP_LEFT" spacing="20" layoutX="50" layoutY="50"
			prefWidth="700">
			<!-- Fancy Header -->
			<Text style="-fx-font-size: 28px; -fx-font-weight: bold;"
				text="CONFIRM BORROW">
				<fill>
					<LinearGradient startX="0" startY="0" endX="1"
						endY="1">
						<stops>
							<Stop offset="0.0" color="#ab5843" />
							<Stop offset="1.0" color="#e8d3cf" />
						</stops>
					</LinearGradient>
				</fill>
				<effect>
					<DropShadow radius="3.0" offsetX="2.0" offsetY="2.0"
						color="#ab5843" />
				</effect>
			</Text>

			<!-- Book ID -->
			<HBox spacing="10" alignment="CENTER_LEFT">
				<Label fx:id="bookIdLabel" text="Book ID:"
					style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ab5843;"
					prefWidth="120" />
				<TextField fx:id="Book_Id" focusTraversable="false"
					promptText="Enter Book ID" prefWidth="300"
					style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-padding: 8; -fx-font-style: italic; -fx-border-radius: 5; -fx-background-radius: 5;" />
			</HBox>

			<!-- Subscriber ID -->
			<HBox spacing="10" alignment="CENTER_LEFT">
				<Label text="Subscriber ID:"
					style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ab5843;"
					prefWidth="120" />
				<TextField fx:id="Subscriber_Id" focusTraversable="false"
					promptText="Enter Subscriber ID" prefWidth="300"
					style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-padding: 8; -fx-font-style: italic; -fx-border-radius: 5; -fx-background-radius: 5;" />
			</HBox>

			<!-- Current Date -->
			<HBox spacing="10" alignment="CENTER_LEFT">
				<Label text="Current Date:"
					style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ab5843;"
					prefWidth="120" />
				<DatePicker fx:id="Current_DatePicker" prefWidth="300"
					style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" />
			</HBox>

			<!-- Return Date -->
			<HBox spacing="10" alignment="CENTER_LEFT">
				<Label text="Return Date:"
					style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ab5843;"
					prefWidth="120" />
				<DatePicker fx:id="Return_DatePicker" prefWidth="300"
					style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" />
			</HBox>

			<!-- Error Label -->
			<Label fx:id="errorLabel" prefHeight="30.0" prefWidth="340.0"
				textAlignment="CENTER" textFill="#ab5843"
				style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-font-style: italic;" />

			<!-- Buttons -->
			<HBox spacing="20" alignment="CENTER_LEFT">
				<Button fx:id="btnConfirm" onAction="#handleConfirm"
					text="Save"
					style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-border-radius: 5; -fx-background-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);" />
				<Button fx:id="ButtonGoToHome" onAction="#handleGoToHome" text="Go to Home"
					style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-border-radius: 5; -fx-background-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);" />
			</HBox>
		</VBox>
	</children>
</AnchorPane>