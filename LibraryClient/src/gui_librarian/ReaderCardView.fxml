<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="550.0" prefWidth="540.0" style="-fx-background-image: url('/BlibBackGround.jpg'); -fx-background-size: 100% 100%; -fx-background-position: center center;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ReaderCardViewController">
	<children>
		<!-- Logo in Top-Right Corner -->
		<ImageView fitHeight="50.0" fitWidth="50.0" preserveRatio="true" AnchorPane.rightAnchor="10" AnchorPane.topAnchor="10">
			<image>
				<Image url="@/Logo.png" />
			</image>
		</ImageView>

		<!-- Main Content -->
		<VBox alignment="CENTER" spacing="15" style="-fx-background-color: #e8d3cf; -fx-padding: 20; -fx-border-color: #ab5843; -fx-border-width: 2px; -fx-border-radius: 5; -fx-background-radius: 5;" AnchorPane.bottomAnchor="50" AnchorPane.leftAnchor="50" AnchorPane.rightAnchor="50" AnchorPane.topAnchor="50">
			<!-- Header -->
			<Text style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Reader Card">
				<fill>
					<LinearGradient endX="1" endY="1" startX="0" startY="0">
						<stops>
							<Stop color="#ab5843" offset="0.0" />
							<Stop color="#e8d3cf" offset="1.0" />
						</stops>
					</LinearGradient>
				</fill>
				<effect>
					<DropShadow color="#ab5843" offsetX="2.0" offsetY="2.0" radius="3.0" />
				</effect>
			</Text>

			<!-- Subscriber Details -->
			<Label fx:id="subscriberIdLabel" style="-fx-font-size: 14px; -fx-text-fill: #333;" text="Subscriber ID: " />
			<Label fx:id="subscriberNameLabel" style="-fx-font-size: 14px; -fx-text-fill: #333;" text="Name: " />
			<Label fx:id="usernameLabel" style="-fx-font-size: 14px; -fx-text-fill: #333;" text="Username: " />
			<Label fx:id="subscriberEmailLabel" style="-fx-font-size: 14px; -fx-text-fill: #333;" text="Email: " />
			<Label fx:id="subscriberPhoneNumberLabel" style="-fx-font-size: 14px; -fx-text-fill: #333;" text="Phone: " />
			<Label fx:id="statusLabel" style="-fx-font-size: 14px; -fx-text-fill: #333;" text="Status: " />

			<!-- Action Buttons -->
			<Label style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #ab5843;" text="Would you like to view:" />
			<Button onAction="#handleViewLoans" prefHeight="40.0" prefWidth="127.0" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10; -fx-border-radius: 5; -fx-background-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);" text="View Loans">
				<font>
					<Font name="System Bold" size="14.0" />
				</font>
			</Button>
			<Button onAction="#handleViewExtensions" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10; -fx-border-radius: 5; -fx-background-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);" text="View Extensions">
				<font>
					<Font name="System Bold" size="14.0" />
				</font>
			</Button>
			<Button onAction="#handleViewOrders" prefHeight="40.0" prefWidth="126.0" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10; -fx-border-radius: 5; -fx-background-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);" text="View Orders">
				<font>
					<Font name="System Bold" size="14.0" />
				</font>
			</Button>
			<Button onAction="#handleActivityHistoryButton" prefHeight="40.0" prefWidth="129.0" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10; -fx-border-radius: 5; -fx-background-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);" text="Activity History">
				<font>
					<Font name="System Bold" size="14.0" />
				</font>
			</Button>

			<!-- Return Button -->
			<Button onAction="#handleReturn" prefHeight="40.0" prefWidth="124.0" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10; -fx-border-radius: 5; -fx-background-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0, 0, 2);" text="Return">
				<font>
					<Font name="System Bold" size="14.0" />
				</font>
			</Button>

		</VBox>
	</children>
</AnchorPane>
