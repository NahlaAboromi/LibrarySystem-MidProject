<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.paint.CycleMethod?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?> <!-- Add this import for Insets -->

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="800.0" spacing="15" style="-fx-background-image: url('/BlibBackGround.jpg'); -fx-background-size: cover; -fx-background-size: 100% 100%; -fx-background-position: center center ;-fx-padding: 20;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LibrarianLoginController">
    <!-- Logo in Top-Right Corner -->
    <ImageView fitHeight="50.0" fitWidth="50.0" preserveRatio="true">
        <image>
            <Image url="@/Logo.png" />
        </image>
        <VBox.margin>
            <Insets top="10" right="10" /> <!-- Proper usage of Insets -->
        </VBox.margin>
    </ImageView>

    <!-- Fancy Header -->
    <Text style="-fx-font-size: 24px; -fx-font-weight: bold;" text="LIBRARIAN LOGIN">
        <fill>
            <LinearGradient startX="0" startY="0" endX="1" endY="1">
                <stops>
                    <Stop offset="0.0" color="#ab5843" />
                    <Stop offset="1.0" color="#e8d3cf" />
                </stops>
            </LinearGradient>
        </fill>
        <effect>
            <DropShadow radius="3.0" offsetX="2.0" offsetY="2.0" color="#ab5843" />
        </effect>
    </Text>
    
    <!-- GridPane for Labels and Input Fields -->
    <GridPane alignment="CENTER" hgap="10" vgap="10">
        <!-- Username Label and Field -->
        <Label style="-fx-text-fill: #ab5843; -fx-font-size: 14px;" text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="usernameField" prefWidth="200" promptText="Librarian Username" style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-prompt-text-fill: #8a4636; -fx-padding: 5; -fx-font-style: italic; -fx-border-radius: 5; -fx-background-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        
        <!-- Password Label and Field -->
        <Label style="-fx-text-fill: #ab5843; -fx-font-size: 14px;" text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <PasswordField fx:id="passwordField" prefWidth="200" promptText="Password" style="-fx-background-color: #e8d3cf; -fx-font-size: 14px; -fx-prompt-text-fill: #8a4636; -fx-padding: 5; -fx-font-style: italic; -fx-border-radius: 5; -fx-background-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        
        <!-- Column and Row Constraints -->
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT" />
            <ColumnConstraints halignment="LEFT" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
        </rowConstraints>
    </GridPane>
    
    <!-- Login Button -->
    <Button fx:id="loginButton" onAction="#handleLogin" prefWidth="200" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-weight: bold; -fx-font-size: 14px; -fx-pref-width: 200px; -fx-pref-height: 40px;" text="Login">
        <effect>
            <DropShadow radius="3.0" offsetX="2.0" offsetY="2.0" color="#ab5843" />
        </effect>
    </Button>
    
    <!-- Error Label -->
    <Label fx:id="errorLabel" style="-fx-text-fill: #ab5843; -fx-font-size: 12px;" />
    
    <!-- Reset Password and Go to Home Section -->
    <GridPane alignment="CENTER" hgap="10" vgap="10">
        <!-- Reset Password Button -->
        <Button fx:id="resetPasswordButton" onAction="#handleResetPassword" prefWidth="200" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-weight: bold; -fx-font-size: 14px; -fx-pref-width: 200px; -fx-pref-height: 40px;" text="Reset Password" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <effect>
                <DropShadow radius="3.0" offsetX="2.0" offsetY="2.0" color="#ab5843" />
            </effect>
        </Button>
        
        <!-- Go to Home Button -->
        <Button fx:id="goToHomeButton" onAction="#handleGoToHome" prefWidth="200" style="-fx-background-color: #ab5843; -fx-text-fill: #e8d3cf; -fx-font-weight: bold; -fx-font-size: 14px; -fx-pref-width: 200px; -fx-pref-height: 40px;" text="Go to Home" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <effect>
                <DropShadow radius="3.0" offsetX="2.0" offsetY="2.0" color="#ab5843" />
            </effect>
        </Button>
        
        <!-- Column and Row Constraints -->
        <columnConstraints>
            <ColumnConstraints />
            <ColumnConstraints />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints />
        </rowConstraints>
    </GridPane>
</VBox>