<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<AnchorPane prefHeight="650.0" prefWidth="800.0"
	style="-fx-background-color: #fbf2ec;"
	xmlns="http://javafx.com/javafx/23.0.1"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="controllers.SubscriberStatusReportController">
	<children>
	            <!-- Logo in Top-Right Corner -->
    <ImageView fitHeight="50.0" fitWidth="50.0" layoutX="700" layoutY="25.0" preserveRatio="true">
        <image>
            <Image url="@/Logo.png" />
        </image>
    </ImageView>
		<!-- Title Label -->
		<Label layoutX="280.0" layoutY="30.0" prefHeight="40.0"
			prefWidth="400.0" style="-fx-font-size: 24px; -fx-font-weight: bold;"
			text="SUBSCRIBER STATUS REPORT">
			<textFill>
				<LinearGradient endX="1" endY="1" startX="0"
					startY="0">
					<stops>
						<Stop color="#ab5843" offset="0.0" />
						<Stop color="#e8d3cf" offset="1.0" />
					</stops>
				</LinearGradient>
			</textFill>
			<effect>
				<DropShadow color="#ab5843" offsetX="2.0" offsetY="2.0"
					radius="3.0" />
			</effect>
		</Label>


		<!-- Year Label and ChoiceBox -->
		<Label layoutX="130.0" layoutY="100.0" prefHeight="30.0"
			prefWidth="80.0" style="-fx-font-size: 14px; -fx-text-fill: #ab5843;"
			text="Year:">
			<font>
				<Font name="System Bold" size="14.0" />
			</font>
		</Label>
		<ChoiceBox fx:id="yearChoiceBox" layoutX="200.0"
			layoutY="100.0" prefWidth="150.0"
			style="-fx-background-color: #e8d3cf; -fx-font-size: 14px;" />

		<!-- Month Label and ChoiceBox -->
		<Label layoutX="130.0" layoutY="150.0" prefHeight="30.0"
			prefWidth="80.0" style="-fx-font-size: 14px; -fx-text-fill: #ab5843;"
			text="Month:">
			<font>
				<Font name="System Bold" size="14.0" />
			</font>
		</Label>
		<ChoiceBox fx:id="monthChoiceBox" layoutX="200.0"
			layoutY="150.0" prefWidth="150.0"
			style="-fx-background-color: #e8d3cf; -fx-font-size: 14px;" />

		<!-- View Button -->
		<Button layoutX="353.0" layoutY="214.0" onAction="#handleView"
			prefHeight="38.0" prefWidth="93.0"
			style="-fx-background-color: #ab5843;" text="View" textFill="#e8d3cf">
			<font>
				<Font name="System Bold" size="14.0" />
			</font>
		</Button>

		<!-- LineChart -->
		<LineChart fx:id="lineChart" layoutX="50.0" layoutY="260.0"
			prefHeight="300.0" prefWidth="700.0"
			style="-fx-background-color: #e8d3cf; -fx-border-color: #ab5843; -fx-border-width: 2;">
			<xAxis>
				<NumberAxis label="Day of the Month" lowerBound="1"
					upperBound="40" fx:id="xAxis" />
			</xAxis>
			<yAxis>
				<NumberAxis fx:id="yAxis" label="Subscribers Status"
					lowerBound="1" upperBound="100" />
			</yAxis>
		</LineChart>

		<!-- Back Button -->
		<Button layoutX="20.0" layoutY="570.0" onAction="#handleBack"
			prefHeight="38.0" prefWidth="116.0"
			style="-fx-background-color: #ab5843;" text="Back" textFill="#e8d3cf">
			<font>
				<Font name="System Bold" size="14.0" />
			</font>
		</Button>

		<!-- Error Label -->
		<Label fx:id="errorLabel" layoutX="269.0" layoutY="183.0"
			prefHeight="30.0" prefWidth="274.0"
			style="-fx-text-fill: red; -fx-font-size: 14px;" text="" />
	</children>
</AnchorPane>